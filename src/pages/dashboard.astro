---
// EduPlatform Starter — Dashboard (facilitator view)
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Dashboard — EduPlatform</title>
  <link rel="stylesheet" href="/src/styles/global.css" />
</head>
<body>
  <header style="background: white; border-bottom: 1px solid var(--color-border); padding: 1rem 0;">
    <div class="container flex justify-between items-center">
      <a href="/" style="text-decoration: none; color: inherit;">
        <strong style="font-size: 1.125rem;">EduPlatform</strong>
      </a>
      <a href="/join" class="btn btn-secondary">Join Session</a>
    </div>
  </header>

  <main class="container" style="padding-top: 2rem; padding-bottom: 2rem;">
    <h1 style="font-size: 1.5rem; font-weight: 700; margin-bottom: 1.5rem;">Dashboard</h1>

    <div id="app">
      <p class="text-secondary">Loading...</p>
    </div>
  </main>

  <script>
    import { h, render } from 'preact';
    import AuthGate from '../components/AuthGate';
    import Dashboard from '../components/Dashboard';

    const App = () =>
      h(AuthGate, {}, (user) => h(Dashboard, { user }));

    render(h(App, null), document.getElementById('app')!);
  </script>
</body>
</html>
